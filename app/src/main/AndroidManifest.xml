<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android" package="com.hindu.lordpromptsai">

    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>

    <application
        android:name=".MyApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:fullBackupContent="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:supportsRtl="true"
        android:resizeableActivity="false"
        android:theme="@style/Theme.BhaktiPromptsAI">

        <!-- 🔹 SPLASH (Android 12+ compliant) -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.BhaktiPromptsAI.Splash">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- 🔹 ONBOARDING -->
        <activity
            android:name=".activities.OnboardingActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"/>

        <!-- 🔹 MAIN -->
        <activity
            android:name=".activities.MainActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 IMAGE DETAIL -->
        <activity
            android:name=".activities.ImageDetailActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 HELP -->
        <activity
            android:name=".activities.HowToUseActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 ABOUT -->
        <activity
            android:name=".activities.AboutActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 RATE -->
        <activity
            android:name=".activities.RateUsActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 PRIVACY -->
        <activity
            android:name=".activities.PrivacyPolicyActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 CREDITS -->
        <activity
            android:name=".activities.CreditsActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 OTHER APPS -->
        <activity
            android:name=".activities.OurOtherAppsActivity"
            android:configChanges="orientation|screenSize"
            android:screenOrientation="portrait"
            android:exported="false"/>

        <!-- 🔹 ADMOB -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-6944458474940814~2926763462"/>

    </application>

</manifest>