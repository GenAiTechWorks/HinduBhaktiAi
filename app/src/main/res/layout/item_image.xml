<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardUseCompatPadding="false">

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <!-- CARD PULSE OVERLAY (Tutorial hint) -->
        <View
            android:id="@+id/cardPulseOverlay"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:visibility="visible"
            android:alpha="0"
            android:background="@drawable/bg_image_pulse"
            android:layout_gravity="center"/>

        <!-- IMAGE -->
        <ImageButton
            android:id="@+id/imageButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:background="@null"
            android:scaleType="centerCrop"
            android:contentDescription="@string/button_image"/>

        <!-- FAVORITE ICON -->
        <ImageButton
            android:id="@+id/favButton"
            android:layout_width="?attr/minTouchTargetSize"
            android:layout_height="?attr/minTouchTargetSize"
            android:layout_gravity="top|end"
            android:layout_marginEnd="2dp"
            android:layout_marginTop="2dp"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="5dp"
            android:src="@drawable/ic_favorite_border"
            android:scaleType="centerInside"
            android:contentDescription="@string/favorite"/>
        <!-- REMOVE (Favorites tab only) -->
        <ImageButton
            android:id="@+id/btnRemove"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="top|end"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="4dp"
            android:background="@android:color/transparent"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:padding="4dp"
            android:src="@drawable/deleteicon"
            android:scaleType="centerInside"
            app:tint="?attr/colorOnSurface"
            android:visibility="gone"
            android:contentDescription="@string/remove_from_favorites"/>

    </FrameLayout>

</androidx.cardview.widget.CardView>