<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:background="@drawable/bg_dialog_card">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- ICON -->
            <ImageView
                android:id="@+id/imgHeaderIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@string/header_icon_image"
                android:src="@drawable/baseline_lightbulb_circle_24"
                app:tint="#FFFFFF"

                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- CLOSE BUTTON -->
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="?attr/minTouchTargetSize"
                android:layout_height="?attr/minTouchTargetSize"
                android:background="@android:color/transparent"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:padding="6dp"
                android:src="@drawable/outline_highlight_off_24"
                android:contentDescription="@string/close_dialog"
                app:tint="@android:color/white"

                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

            <!-- TITLE -->
            <TextView
                android:id="@+id/tvHeaderTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"

                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"

                android:text="@string/how_to_use"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:textStyle="bold"

                android:maxLines="2"
                android:ellipsize="end"

                app:layout_constraintStart_toEndOf="@id/imgHeaderIcon"
                app:layout_constraintEnd_toStartOf="@id/btnClose"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- STEP 1 -->
        <TextView
            android:text="@string/_1_copy_the_prompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:text="@string/_1_copy_the_prompt_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BFFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- STEP 2 -->
        <TextView
            android:text="@string/_2_choose_ai_tool"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:text="@string/_2_choose_ai_tool_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BFFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- STEP 3 -->
        <TextView
            android:text="@string/_3_paste_your_prompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:text="@string/_3_paste_your_prompt_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BFFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="12dp" />

        <!-- STEP 4 -->
        <TextView
            android:text="@string/_4_generate_your_divine_image"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:textSize="16sp" />

        <TextView
            android:text="@string/_4_generate_your_divine_image_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#BFFFFFFF"
            android:textSize="14sp"
            android:layout_marginBottom="16dp" />

        <!-- PRO TIP -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="14dp"
            android:background="@drawable/bg_pro_tip_ai"
            android:minHeight="56dp">

            <ImageView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:contentDescription="@string/outline_star"
                android:src="@drawable/outline_star_shine_24"
                app:tint="#FFD54F" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="10dp"
                android:text="@string/_5_pro_tip"
                android:textColor="#FFD54F"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>