<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="18dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/step_card_bg">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingVertical="12dp"
        android:paddingHorizontal="14dp">

        <!-- 🔢 STEP NUMBER -->
        <TextView
            android:id="@+id/tvStepNumber"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:gravity="center"
            android:text="@string/_1"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_step_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- 📝 STEP TITLE -->
        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:layout_marginStart="12dp"
            app:layout_constraintStart_toEndOf="@id/tvStepNumber"
            app:layout_constraintTop_toTopOf="@id/tvStepNumber"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 📄 STEP DESCRIPTION -->
        <TextView
            android:id="@+id/tvStepDescription"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="#D6D9E0"
            android:layout_marginTop="6dp"
            app:layout_constraintStart_toStartOf="@id/tvStepTitle"
            app:layout_constraintTop_toBottomOf="@id/tvStepTitle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>