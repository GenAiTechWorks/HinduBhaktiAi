<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingEnd="16dp"
    android:paddingTop="60dp"
    android:paddingBottom="16dp"
    android:background="?attr/colorPrimary">

    <!-- ICON + TITLE ROW -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- APP LOGO / CAMERA ICON -->
        <ImageView
            android:id="@+id/imgHeaderIcon"
            android:layout_width="?attr/minTouchTargetSize"
            android:layout_height="?attr/minTouchTargetSize"
            android:src="@drawable/appstore"
            android:contentDescription="@string/app_name"
            android:scaleType="fitCenter" />

        <!-- TITLE -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="@string/hindu_bhakti_ai"
            android:textColor="?attr/colorOnPrimary"

            android:maxLines="1"
            android:ellipsize="end"

            android:insetLeft="0dp"
            android:insetRight="0dp"
            android:paddingHorizontal="4dp"

            app:autoSizeTextType="uniform"
            app:autoSizeMinTextSize="6sp"
            app:autoSizeMaxTextSize="14sp"
            app:autoSizeStepGranularity="1sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- SUBTITLE / TAGLINE -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/create_divine_ai_prompts"
        android:textColor="?attr/colorOnPrimary"
        android:maxLines="1"
        android:ellipsize="end"

        android:insetLeft="0dp"
        android:insetRight="0dp"

        app:autoSizeTextType="uniform"
        app:autoSizeMinTextSize="4sp"
        app:autoSizeMaxTextSize="10sp"
        app:autoSizeStepGranularity="1sp"
        android:alpha="0.85" />

</LinearLayout>