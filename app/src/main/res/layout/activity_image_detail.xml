<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent">

    <!-- ================= VIDEO BACKGROUND (FULL SCREEN) ================= -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/backgroundVideoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:keepScreenOn="true"
        android:focusable="false"
        android:focusableInTouchMode="false"/>

    <!--<View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"/>-->

    <!-- ================= APP BAR ================= -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarImageActivity"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            style="@style/AppToolbarStyle"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@android:color/transparent"
            app:titleCentered="true">

            <TextView
                android:id="@+id/detailTitle"
                style="@style/TextPrimary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="@string/prompt_app"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </com.google.android.material.appbar.MaterialToolbar>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ================= CONTENT ================= -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/transparent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- ================= IMAGE CARD ================= -->
        <androidx.cardview.widget.CardView
            android:id="@+id/imageCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="8dp"
            android:background="@android:color/transparent"
            app:cardBackgroundColor="@android:color/transparent"
            app:cardCornerRadius="18dp"
            app:cardElevation="4dp"
            app:cardUseCompatPadding="false"
            app:cardPreventCornerOverlap="false"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/actionRow"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <!-- IMAGE -->
                <ImageView
                    android:id="@+id/detailImage"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:contentDescription="@string/detail_image"
                    android:scaleType="fitXY"
                    android:layerType="hardware"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- 🔵 IMAGE PULSE (Tutorial hint) -->
                <View
                    android:id="@+id/imagePulseOverlay"
                    android:layout_width="?attr/minTouchTargetSize"
                    android:layout_height="?attr/minTouchTargetSize"
                    android:visibility="visible"
                    android:alpha="0"
                    android:background="@drawable/bg_image_pulse"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- IMAGE COUNTER -->
                <TextView
                    android:id="@+id/imageCounter"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_margin="8dp"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:background="@drawable/counter_bg"
                    android:textColor="?attr/colorOnPrimary"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>

                <!-- FAVORITE -->
                <ImageButton
                    android:id="@+id/favButton"
                    android:layout_width="?attr/minTouchTargetSize"
                    android:layout_height="?attr/minTouchTargetSize"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/fav_button"
                    android:foreground="?attr/selectableItemBackgroundBorderless"
                    android:padding="8dp"
                    android:src="@drawable/ic_heart_filled"
                    app:layout_constraintTop_toBottomOf="@id/imageCounter"
                    app:layout_constraintEnd_toEndOf="parent"
                    android:layout_marginTop="8dp"/>

                <!-- GUIDELINE (prompt starts below mid image) -->
                <androidx.constraintlayout.widget.Guideline
                    android:id="@+id/promptGuide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    app:layout_constraintGuide_percent="0.60"/>

                <!-- PROMPT GLASS OVERLAY -->
                <FrameLayout
                    android:id="@+id/promptContainer"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:visibility="gone"
                    android:background="@drawable/bg_glass_prompt"
                    android:padding="12dp"
                    app:layout_constraintTop_toBottomOf="@id/promptGuide"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent">

                    <ScrollView
                        android:id="@+id/promptScrollView"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:overScrollMode="ifContentScrolls">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:id="@+id/tvPromptTitle"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/ai_prompt"
                                android:textStyle="bold"
                                android:textSize="16sp"
                                android:textColor="@android:color/white"
                                android:layout_marginBottom="8dp"/>

                            <TextView
                                android:id="@+id/descriptionText"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:textColor="@android:color/white"
                                android:lineSpacingExtra="4dp"/>
                        </LinearLayout>
                    </ScrollView>

                </FrameLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>

        <!-- ================= ACTION ROW ================= -->
        <LinearLayout
            android:id="@+id/actionRow"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp"
            android:orientation="horizontal"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/imageCard"
            app:layout_constraintBottom_toTopOf="@id/adContainer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPromptAction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/generate_prompt"
                android:textAllCaps="false"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:maxLines="1"
                android:ellipsize="end"

                android:insetLeft="0dp"
                android:insetRight="0dp"
                android:paddingHorizontal="2dp"

                app:autoSizeTextType="uniform"
                app:autoSizeMinTextSize="5sp"
                app:autoSizeMaxTextSize="14sp"
                app:autoSizeStepGranularity="1sp"

                android:background="@drawable/bg_copy_prompt_pink"
                app:backgroundTint="@null"/>
            <View
                android:layout_width="8dp"
                android:layout_height="1dp"/>

            <ImageButton
                android:id="@+id/btnHelpDetails"
                android:layout_width="?attr/minTouchTargetSize"
                android:layout_height="?attr/minTouchTargetSize"
                android:background="@android:color/transparent"
                android:contentDescription="@string/helper_details"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:scaleType="fitCenter"
                android:importantForAccessibility="yes"
                android:hapticFeedbackEnabled="true"
                android:src="@drawable/rounded_help_24"
                app:tint="#FFFFFF"/>

           <!-- app:tint="#F39A5C"-->

            <View
                android:layout_width="8dp"
                android:layout_height="1dp"/>

            <ImageButton
                android:id="@+id/btnYoutube"
                android:layout_width="?attr/minTouchTargetSize"
                android:layout_height="?attr/minTouchTargetSize"
                android:background="@android:color/transparent"
                android:contentDescription="@string/youtube_button"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/youtube"
                android:scaleType="centerInside"/>


        </LinearLayout>

        <!-- ================= AD ================= -->
        <FrameLayout
            android:id="@+id/adContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:visibility="visible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <include layout="@layout/layout_ad_banner"/>
        </FrameLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>