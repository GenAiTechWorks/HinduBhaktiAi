<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TabTextStyle">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Tab text style: bold & centered -->
    <style name="TabTextBold">
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TOOLBAR -->
    <style name="AppToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="android:background">?attr/colorPrimary</item>
        <item name="titleTextColor">?attr/colorOnPrimary</item>
        <item name="navigationIconTint">?attr/colorOnPrimary</item>
    </style>

    <!-- CARD -->
    <style name="AppCardStyle">
        <item name="cardBackgroundColor">?attr/colorSurface</item>
    </style>

    <!-- TEXT PRIMARY -->
    <style name="TextPrimary">
        <item name="android:textColor">?attr/colorOnPrimary</item>
    </style>

    <!-- ICON -->
    <style name="IconPrimary">
        <item name="android:tint">?attr/colorOnSurface</item>
    </style>

    <style name="NavDrawerItemTextLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>